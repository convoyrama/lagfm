# Configuración de Variables de Entorno (Local)
# Copia este archivo a .env para habilitar las URLs de datos

# URL donde residen los JSON de configuración y el APK (ej: https://tudominio.com/lagfm)
VITE_DATA_URL=https://convoyrama.github.io/lagfm

# URL principal del sitio o marca (ej: https://tudominio.com)
VITE_SITE_URL=https://convoyrama.github.io
