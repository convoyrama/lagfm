{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LAGFM",
  "version": "6.0.1",
  "identifier": "com.convoyrama.lagfm",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LAGFM",
        "width": 300,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: https: data:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' tauri: asset: https: data:; connect-src 'self' tauri: https: http:; media-src 'self' tauri: http: https: asset: data:;"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
